# ── KiCad ────────────────────────────────────────────────────────────────────
# https://www.kicad.org/ | https://kicad.org/help/file-formats/

# Temporary / backup files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Exported files (regenerated from source) — scoped to KiCad project folder
Flight_Controller/*.net
Flight_Controller/*.dsn
Flight_Controller/*.ses
Flight_Controller/*.xml
Flight_Controller/*.csv

# Archived backups (KiCad 6+)
**/*-backups/*.zip

# Per-machine local settings
*.kicad_prl


# ── PlatformIO ───────────────────────────────────────────────────────────────

# Build output and package cache (reproducible via `pio run`)
.pio/


# ── VS Code ──────────────────────────────────────────────────────────────────

# Generated by PlatformIO — machine-specific, not portable
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
.vscode/.browse.c_cpp.db*

# Keep: .vscode/extensions.json (extension recommendations)
# Keep: .vscode/settings.json  (shared workspace settings)


# ── MATLAB ───────────────────────────────────────────────────────────────────

*.asv


# ── OS ───────────────────────────────────────────────────────────────────────

.DS_Store
Thumbs.db
